# LLM Benchmark App - Environment Variables

# API Keys for LLM Providers (UIでも入力可能)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=sk-or-v1-...

# Judge Models (optional defaults)
# アプリはUIでjudgeモデルを選択します。
JUDGE_OPENAI_MODEL=gpt-4o
JUDGE_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
JUDGE_GEMINI_MODEL=gemini-1.5-pro
JUDGE_OPENROUTER_MODEL=openai/gpt-4o

# Resource path overrides (optional)
# LLM_BENCHMARK_RUBRICS_DIR=/absolute/path/to/rubrics
# LLM_BENCHMARK_PROMPTS_DIR=/absolute/path/to/prompts
# LLM_BENCHMARK_JUDGE_SYSTEM_PROMPT_PATH=/absolute/path/to/judge_system_prompt.md
